rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    function isAnyAdmin() {
      // Optimized check: checks the requester's own doc once
      return request.auth != null && 
             (exists(/databases/$(database)/documents/users/admin/accounts/$(request.auth.uid)) || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'admin');
    }

    function isNotBlocked() {
      // Allow if the document exists and isBlocked is NOT true
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked != true;
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      // Users can always read their own doc (needed to see they are blocked)
      // Admins can list and read all users
      allow read: if request.auth != null && (request.auth.uid == userId || isAnyAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAnyAdmin());
    }

    match /users/{userType}/accounts/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAnyAdmin());
    }

    // --- WAREHOUSES ---
    match /{path=**}/warehouses/{warehouseId} {
      // Public read remains allowed
      allow read: if true;
      // Deny creation/updates if user is blocked
      allow create, update, delete: if request.auth != null && isNotBlocked();
    }
    
    // --- MESSAGING ---
    match /conversations/{convId} {
      // Deny access to conversations if user is blocked
      allow read, write: if request.auth != null && isNotBlocked() && (
        resource == null || 
        request.auth.uid == resource.data.merchantId || 
        request.auth.uid == resource.data.ownerId ||
        isAnyAdmin()
      );
         
      match /messages/{msgId} {
        allow read, write: if request.auth != null && isNotBlocked();
      }
    }

    // --- PRESERVED RULES ---
    match /{path=**}/accounts/{userId} {
      allow read: if request.auth != null || true; // Needed for pre-auth email check
    }

    match /visitors/{docId} {
      allow read, write: if true;
    }

    match /feedbacks/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null && isNotBlocked();
    }

    match /warehouse_availability/{monthKey}/entries/{entryId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isNotBlocked();
    }

    match /contact_details/{role}/users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAnyAdmin());
    }
  }
}
