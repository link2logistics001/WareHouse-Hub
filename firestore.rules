rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- USER PROFILES ---
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- COLLECTIONGROUP RULE FOR 'warehouses' ---
    // Required for collectionGroup queries used by Admin, Merchant browse, and Search page.
    // This rule matches ANY subcollection named 'warehouses' anywhere in the DB.
    match /{path=**}/warehouses/{warehouseId} {
      allow read: if true;  // Public read for approved warehouses; app filters by status
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
    
    // --- VISITORS ---
    match /visitors/{docId} {
      allow read, write: if true;
    }

    // --- WAREHOUSE AVAILABILITY ---
    match /warehouse_availability/{monthKey}/entries/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.owner_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.owner_id == request.auth.uid
        && request.resource.data.owner_id == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.owner_id == request.auth.uid;
    }

    // --- SECURE & ORGANIZED MESSAGING ---
    match /conversations/{convId} {
      allow read: if request.auth != null && (
        resource == null || 
        request.auth.uid == resource.data.merchantId || 
        request.auth.uid == resource.data.ownerId
      );
      
      allow write: if request.auth != null && (
        (resource == null && request.auth.uid == request.resource.data.merchantId) ||
        (resource != null && (request.auth.uid == resource.data.merchantId || request.auth.uid == resource.data.ownerId))
      );
         
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
