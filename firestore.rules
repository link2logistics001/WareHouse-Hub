rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isAdmin(uid) {
      return exists(/databases/$(database)/documents/users/admin/accounts/$(uid)) ||
             (exists(/databases/$(database)/documents/users/$(uid)) &&
              get(/databases/$(database)/documents/users/$(uid)).data.userType == 'admin');
    }

    function isAnyAdmin() {
      return request.auth != null && isAdmin(request.auth.uid);
    }

    function isNotBlocked() {
      // Robust check: ensures we don't crash if isBlocked is missing
      return request.auth != null && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        !('isBlocked' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked != true
      );
    }

    // --- OLD USER PROFILES ---
    match /users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAnyAdmin());

      allow write: if request.auth != null &&
        (request.auth.uid == userId || isAnyAdmin());
    }

    // --- NEW USER PROFILES ---
    match /users/{userType}/accounts/{userId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || isAnyAdmin());
    }

    // --- WAREHOUSES (COLLECTION GROUP SUPPORT) ---
    match /{path=**}/warehouses/{warehouseId} {
      allow read: if true; // public
      allow create, update, delete: if request.auth != null && isNotBlocked();
    }

    // --- ACCOUNTS (COLLECTION GROUP QUERY SUPPORT) ---
    match /{path=**}/accounts/{userId} {
      allow read: if true; // needed for auth/email lookup
    }

    // --- VISITORS ---
    match /visitors/{docId} {
      allow read, write: if true;
    }

    // --- FEEDBACKS ---
    match /feedbacks/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null && isNotBlocked();
    }

    // --- WAREHOUSE AVAILABILITY ---
    match /warehouse_availability/{monthKey}/entries/{entryId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null &&
        isNotBlocked() &&
        request.resource.data.owner_id == request.auth.uid;

      allow update: if request.auth != null &&
        isNotBlocked() &&
        resource.data.owner_id == request.auth.uid &&
        request.resource.data.owner_id == request.auth.uid;

      allow delete: if request.auth != null &&
        isNotBlocked() &&
        resource.data.owner_id == request.auth.uid;
    }

    // --- CONTACT DETAILS ---
    match /contact_details/{role}/users/{userId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == userId || isAnyAdmin());
    }

    // --- MESSAGING ---
    match /conversations/{convId} {

      allow read: if request.auth != null &&
        isNotBlocked() &&
        (
          resource == null ||
          request.auth.uid == resource.data.merchantId ||
          request.auth.uid == resource.data.ownerId ||
          isAnyAdmin()
        );

      allow write: if request.auth != null &&
        isNotBlocked() &&
        (
          (resource == null && request.auth.uid == request.resource.data.merchantId) ||
          (resource != null &&
            (
              request.auth.uid == resource.data.merchantId ||
              request.auth.uid == resource.data.ownerId ||
              isAnyAdmin()
            )
          )
        );

      match /messages/{msgId} {
        allow read, write: if request.auth != null && isNotBlocked();
      }
    }
  }
}
